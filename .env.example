# =============================================================================
# Configurazione progetto - copiare in .env e personalizzare
# =============================================================================

# Nome univoco del progetto (obbligatorio).
# Usato per i nomi dei volumi Docker. Deve essere diverso per ogni istanza.
PROJECT_NAME=CHANGE_ME

# Porta del frontend in produzione (obbligatorio).
# Vale sia lato host sia dentro al container Node SSR.
# Ogni progetto sulla stessa VPS deve usare una porta diversa (es. 3000, 3001, 3002).
FRONTEND_PORT=3000

# Porta del backend in produzione.
# Vale sempre dentro alla rete Docker e, se usi docker-compose.backend-exposed.yml,
# viene pubblicata uguale anche sull'host.
BACKEND_PORT=8080

# Porte di sviluppo (opzionali, hanno default).
DEV_FRONTEND_PORT=4200
DEV_BACKEND_PORT=5000

# API key per il frontend (default: frontend).
API_KEY=frontend

# Timeout del proxy Node SSR verso il backend (ms). Default: 30000 (30s).
# Aumentare per endpoint lenti (es. elaborazioni lunghe), abbassare per fail-fast.
# PROXY_TIMEOUT_MS=30000

# URL base del backend (opzionale).
# Vuoto = stesso host, il frontend Node SSR proxya /api/* al backend.
# Valorizzato = il frontend chiama direttamente il backend remoto.
API_URL=

# URL pubblico canonico del sito, usato in fase di build per generare sitemap.xml.
# Esempio: https://miosito.it
# Se vuoto, la build funziona comunque ma la sitemap usa https://example.com e mostra un warning.
SITEMAP_BASE_URL=

# Nome del progetto Angular — corrisponde al nome in angular.json e alla cartella dist/.
# Cambiare SOLO se si rinomina il progetto rispetto al template (br1-web-engine).
# Deve essere aggiornato sia qui (usato da build e runtime) che in angular.json.
# DIST_PATH=br1-web-engine

# --- Security headers frontend (Node SSR) ---
# Applicati alle risposte HTML e agli asset statici. Le API ricevono i propri header dal backend.
# Sovrascrivere solo se il progetto derivato ha bisogni specifici (CDN, analytics, Google Fonts, ecc.).
# Se API_URL è valorizzato, connect-src lo include automaticamente — non serve aggiungerlo qui.
#
# SECURITY_CSP=default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; connect-src 'self'; frame-ancestors 'self'; base-uri 'self'; form-action 'self'
# SECURITY_X_FRAME_OPTIONS=SAMEORIGIN
# SECURITY_REFERRER_POLICY=strict-origin-when-cross-origin
# SECURITY_PERMISSIONS_POLICY=camera=(), microphone=(), geolocation=()

# --- Segreti backend (sovrascrivono appsettings.json) ---
# Decommentare e valorizzare in produzione:

# Security__ApiKeys__0=frontend
# Security__Token__SecretKey=CAMBIAMI_MIN_32_CHARS

# Durata del token JWT in secondi (default: 3000 = 50 min).
# Security__Token__ExpirationSeconds=3000

# Origini CORS consentite. OBBLIGATORIO in produzione: senza questo il backend
# accetta richieste da qualsiasi dominio (AllowAnyOrigin).
# Security__CorsOrigins__0=https://miosito.it

# Impostare true se il backend è dietro un reverse proxy (Nginx, Cloudflare, ecc.).
# Necessario affinché il rate limiter veda l'IP reale del client invece dell'IP
# del proxy — altrimenti un singolo IP di proxy blocca tutti gli utenti insieme.
# Security__BehindProxy=false

# Lingue supportate dal backend. Devono corrispondere a quelle configurate in
# site.ts (availableLanguages) nel frontend.
# Localization__DefaultLanguage=it
# Localization__SupportedLanguages__0=it
# Localization__SupportedLanguages__1=en
