# =============================================================================
# Configurazione progetto — copiare in .env e personalizzare
# =============================================================================

# Nome univoco del progetto (obbligatorio).
# Usato da Docker Compose per nominare i volumi (built-in COMPOSE_PROJECT_NAME).
# Deve essere diverso per ogni istanza sulla stessa macchina.
COMPOSE_PROJECT_NAME=CHANGE_ME

# Porta del frontend in produzione (obbligatorio).
FRONTEND_PORT=3000

# Porta del backend in produzione (opzionale, default 8080).
# Usata dal healthcheck host e, se usi docker-compose.backend-exposed.yml,
# viene pubblicata sull'host.
# BACKEND_PORT=8080

# Porte di sviluppo (opzionali, hanno default).
# DEV_FRONTEND_PORT=4200
# DEV_BACKEND_PORT=5000

# Host assoluto del backend per le chiamate proxy e SSR (default: http://backend:8080).
# In produzione Docker usa il nome del servizio — cambia solo per deploy su host separati.
# BACKEND_ORIGIN=http://backend:8080

# API key usata dal proxy Node per autenticarsi con il backend.
# Deve coincidere con Security.ApiKeys nel backend.
# BACKEND_API_KEY=frontend

# URL pubblico canonico del sito, usato a build time per generare sitemap.xml.
# Se vuoto, la build funziona ma la sitemap usa https://example.com con warning.
# SITEMAP_BASE_URL=https://miosito.it

# --- Impostazioni chieste da deploy.sh ---
# Vengono chieste interattivamente alla prima esecuzione e scritte in .env.
# Valorizzarle qui per saltare le domande (es. CI/CD).

# Espone la porta backend sull'host (richiede docker-compose.backend-exposed.yml).
# EXPOSE_BACKEND=no
