{
  "name": "br1-web-engine",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve --open --ssl false --proxy-config proxy.local.conf.json",
    "start:docker": "ng serve --ssl false --proxy-config proxy.docker.conf.json",
    "prestart": "npm run generate:site-meta",
    "prestart:docker": "npm run generate:site-meta",
    "generate:site-meta": "tsx scripts/generate-site-meta.ts",
    "generate:sitemap": "tsx scripts/generate-sitemap.ts",
    "generate:icons": "tsx scripts/generate-icons.ts",
    "prebuild": "npm run generate:site-meta && npm run generate:sitemap",
    "build": "ng build",
    "serve:ssr": "node dist/br1-web-engine/server/server.mjs",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "dependencies": {
    "@angular/animations": "^19.0.0",
    "@angular/cdk": "^19.0.0",
    "@angular/common": "^19.0.0",
    "@angular/compiler": "^19.0.0",
    "@angular/core": "^19.0.0",
    "@angular/forms": "^19.0.0",
    "@angular/platform-browser": "^19.0.0",
    "@angular/platform-browser-dynamic": "^19.0.0",
    "@angular/platform-server": "^19.2.20",
    "@angular/router": "^19.0.0",
    "@angular/service-worker": "^19.0.0",
    "@angular/ssr": "^19.2.23",
    "@fortawesome/fontawesome-free": "^6.5.1",
    "@types/express": "^5.0.6",
    "bootstrap": "^5.3.3",
    "express": "^5.2.1",
    "marked": "^15.0.0",
    "rxjs": "~7.8.0",
    "sweetalert2": "^11.0.0",
    "tslib": "^2.6.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^19.0.0",
    "@angular/cli": "^19.0.0",
    "@angular/compiler-cli": "^19.0.0",
    "eslint": "^10.1.0",
    "sharp": "^0.33.0",
    "tsx": "^4.19.0",
    "typescript": "~5.6.0"
  }
}
